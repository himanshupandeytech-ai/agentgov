# Copy to .env and adjust. agentgov runs offline with no .env at all.

# Knowledge backend: "yaml" (default, offline) or "db" (uses docker-compose stack).
AGENTGOV_BACKEND=yaml

# Used only when AGENTGOV_BACKEND=db (matches docker-compose.yml):
DATABASE_URL=postgresql://agentgov:agentgov@localhost:5432/governance
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=agentgovpass
